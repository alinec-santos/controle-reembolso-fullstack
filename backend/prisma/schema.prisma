generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COLABORADOR
  GESTOR
  FINANCEIRO
  ADMIN
}

enum RequestStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REJEITADO
  PAGO
  CANCELADO
}

enum RequestAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  CANCELED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests  ReimbursementRequest[]
  histories RequestHistory[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests ReimbursementRequest[]

  @@map("categories")
}

model ReimbursementRequest {
  id              String        @id @default(uuid())
  userId          String
  categoryId      String
  description     String
  amount          Decimal
  expenseDate     DateTime
  status          RequestStatus @default(RASCUNHO)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User             @relation(fields: [userId], references: [id])
  category    Category         @relation(fields: [categoryId], references: [id])
  attachments Attachment[]
  histories   RequestHistory[]

  @@map("reimbursement_requests")
}

model Attachment {
  id        String   @id @default(uuid())
  requestId String
  fileName  String
  fileType  String
  fileUrl   String
  createdAt DateTime @default(now())

  request ReimbursementRequest @relation(fields: [requestId], references: [id])

  @@map("attachments")
}

model RequestHistory {
  id          String        @id @default(uuid())
  requestId   String
  userId      String
  action      RequestAction
  observation String?
  createdAt   DateTime      @default(now())

  request ReimbursementRequest @relation(fields: [requestId], references: [id])
  user    User                 @relation(fields: [userId], references: [id])

  @@map("request_histories")
}